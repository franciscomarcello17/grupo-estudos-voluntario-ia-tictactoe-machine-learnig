{
  "openapi": "3.0.1",
  "info": {
    "title": "JogoDaVelhaIA.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Jogo/novo": {
      "post": {
        "tags": [
          "Jogo"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Jogo/jogar": {
      "post": {
        "tags": [
          "Jogo"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JogadaViewModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/JogadaViewModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/JogadaViewModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Jogo/jogar-ia/{partidaId}": {
      "post": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "partidaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Jogo/tabuleiro/{partidaId}": {
      "get": {
        "tags": [
          "Jogo"
        ],
        "parameters": [
          {
            "name": "partidaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Treinamento/iniciar": {
      "post": {
        "tags": [
          "Treinamento"
        ],
        "parameters": [
          {
            "name": "episodios",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Treinamento/parametros": {
      "post": {
        "tags": [
          "Treinamento"
        ],
        "parameters": [
          {
            "name": "taxaAprendizado",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0,1
            }
          },
          {
            "name": "fatorDesconto",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0,9
            }
          },
          {
            "name": "epsilon",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0,3
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JogadaViewModel": {
        "type": "object",
        "properties": {
          "partidaId": {
            "type": "integer",
            "format": "int32"
          },
          "posicao": {
            "type": "integer",
            "format": "int32"
          },
          "simbolo": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}